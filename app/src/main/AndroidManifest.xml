<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Essential permissions for mock location mapping -->
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_MOCK_LOCATION" tools:ignore="MockLocation" />

    <!-- Foreground services and types on modern Android packages -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_LOCATION" />
    
    <!-- Floating overlay window widget drawer -->
    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW" />
    
    <!-- Push messaging notifications updates -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    
    <!-- Network connectivity metrics lookups -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    
    <!-- Boot restorations features service start -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

    <application
        android:name="com.muawiya.fakegps.FakeGpsApplication"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/AppTheme"
        android:usesCleartextTraffic="true">

        <!-- Google Maps API Key parameters mapping -->
        <meta-data
            android:name="com.google.android.geo.API_KEY"
            android:value="AIzaSyBAZZ82P6o66hgAZvg-W_EILYCCt_fr73Y" />

        <!-- Launcher Dashboard Context main screen activity -->
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:label="@string/app_name">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>



        <!-- Continuous coordinate spoofers provider service -->
        <service
            android:name=".service.MockLocationService"
            android:foregroundServiceType="location"
            android:exported="false" />

    </application>
</manifest>
